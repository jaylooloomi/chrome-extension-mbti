{
  "manifest_version": 3,
  "name": "MBTI Personality Test",
  "version": "1.0.0",
  "description": "AI-powered MBTI personality assessment extension",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open MBTI Test"
  },
  "icons": {
    "16": "icons/icon-Photoroom.png",
    "32": "icons/icon-Photoroom.png",
    "48": "icons/icon-Photoroom.png",
    "128": "icons/icon-Photoroom.png"
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://generativelanguage.googleapis.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
  }
}